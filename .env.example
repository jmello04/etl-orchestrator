# ─── Banco de dados ───────────────────────────────────────────────
DATABASE_URL=postgresql://etl_user:etl_password@localhost:5432/etl_db
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=etl_password
POSTGRES_DB=etl_db

# ─── Aplicação ────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Prefect ──────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ─── CORS (lista JSON de origens permitidas) ──────────────────────
# Desenvolvimento: permite localhost
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# Produção: substitua pelas URLs reais da sua aplicação
# CORS_ORIGINS=["https://meuapp.com","https://admin.meuapp.com"]
